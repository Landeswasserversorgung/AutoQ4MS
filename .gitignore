# -------------------------------------------------------
# MATLAB .gitignore
# -------------------------------------------------------

# MATLAB automatically generated files
*.asv             # Autosave files
*.m~              # Temporary m-files
*.mex*            # Compiled MEX files
*.p               # Protected MATLAB files
*.slprj/          # Simulink Project Cache
*.autosave        # Simulink Autosave files
*.mdl.r20*        # Old Simulink backup files
*.slx.r20*        # Old Simulink backup files
*.bak             # Backup files

# MATLAB cache and temporary folders
cache/
codegen/
slprj/
work/
mex/
tmp/
temp/
data/import/mslib/

# MATLAB Live Script autosave files
*.mlx.autosave
*.asv

# OS-specific files
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Custom project structure
# -------------------------------------------------------

# Exclude the entire resources folder and its contents
resources/

*.sql
*.log
!PivotQueryTemplate.sql
*.xlsx
!Components_template.xlsx
!InternalStandards_template.xlsx
*.html
!emailstartTemplate.html
*.mat
*.bat
!template.bat



